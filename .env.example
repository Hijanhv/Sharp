# ── Sharp ASP configuration ────────────────────────────────────────────────
# Copy to `.env` and fill in. Everything has a safe default for local dev.

# Public base URL of THIS service once deployed (used in x402 challenge + report links).
# Local dev: http://localhost:8787
PUBLIC_BASE_URL=http://localhost:8787
PORT=8787
HOST=0.0.0.0

# ── Payments ───────────────────────────────────────────────────────────────
# off  -> every tool is FREE (HTTP 200). Use this to register + go live fast.
# x402 -> paid tools return HTTP 402 + PAYMENT-REQUIRED challenge, settle on X Layer.
PAYMENT_MODE=off

# Your X Layer (chainId 196) receiving wallet — from your OKX Agentic Wallet.
# Required only when PAYMENT_MODE=x402.
PAYMENT_PAY_TO=0x0000000000000000000000000000000000000000

# Settlement asset on X Layer. Default is USDT0 (the official OKX.AI stablecoin).
PAYMENT_ASSET=0x779ded0c9e1022225f8e0630b35a9b54be713736

# OKX x402 facilitator URL (from ASP registration) for on-chain verification.
# When unset in x402 mode, Sharp still returns a compliant 402 challenge but will
# not verify settlement (fine for review self-check; set before taking real money).
PAYMENT_FACILITATOR_URL=

# ── Data sources (all optional; Sharp ships with a bundled model prior) ──────
# Polymarket public Gamma API base. No key required.
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
# Set to "1" to disable outbound network calls (uses bundled fixtures only).
OFFLINE=0
